<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FigurasQE</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/FigurasQE_WebClient.styles.css" asp-append-version="true" />
</head>

<body class="d-flex flex-column min-vh-100">

    <main role="main" class="flex-grow-1 d-flex flex-column justify-content-center align-items-center text-center">

        @RenderBody()

    </main>

    <footer class="footer text-muted py-2">
        <div class="container-fluid text-start">
            &copy; 2026 - FigurasQE -
            <a asp-area="" asp-page=" /Privacy">Privacy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>
